# ============================================================
# BOLHA - VARIÁVEIS DE AMBIENTE (TEMPLATE)
# Copie este arquivo para .env e preencha os valores
# ============================================================

# CONFIGURAÇÕES DA APLICAÇÃO
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# BANCO DE DADOS (MongoDB Atlas)
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/bolha?retryWrites=true&w=majority

# SEGURANÇA E CRIPTOGRAFIA
JWT_SECRET=sua_chave_secreta_access_token_aqui
JWT_REFRESH_SECRET=sua_chave_secreta_refresh_token_aqui

# AUTENTICAÇÃO GOOGLE OAUTH 2.0
GOOGLE_CLIENT_ID=seu_client_id_google
GOOGLE_CLIENT_SECRET=seu_client_secret_google
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# REGRAS DE NEGÓCIO DA BOLHA
LEAK_SCORE_THRESHOLD=12

# CLOUDINARY (Armazenamento de Mídias)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
