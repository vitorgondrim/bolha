# ============================================================
# BOLHA - REDE SOCIAL EFÊMERA
# Arquivo: .gitignore (Configuração Profissional)
# ============================================================

# 🔐 SEGURANÇA E AMBIENTE (Crucial)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 📦 DEPENDÊNCIAS
node_modules/
jspm_packages/
web_modules/

# 🚀 BUILDS E SAÍDAS
dist/
build/
.cache/
.parcel-cache/

# 🖼️ UPLOADS LOCAIS (Evita enviar fotos de teste para o GitHub)
backend/uploads/*
!backend/uploads/.gitkeep

# 📋 LOGS E DIAGNÓSTICOS
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 💻 CONFIGURAÇÕES DE SISTEMA (Mac/Windows)
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# 🛠️ CONFIGURAÇÕES DE IDE/EDITOR
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp